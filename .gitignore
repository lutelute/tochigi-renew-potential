# 生成されたHTML・GeoJSON（大容量、再生成可能）
output/*/*.html
output/*/*.geojson
output/*/*.png

# ダウンロードした大容量GISデータ（再取得可能）
data/*/land/

# All-Japan-Gridから抽出したGeoJSON（再生成可能）
data/*/grid/*.geojson

# ポテンシャルGeoJSON（再生成可能）
data/*/potential/*.geojson

# 道路GeoJSON
data/*/grid/*_roads.geojson

# PDFは転載禁止のため除外
data/*/*.pdf

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/

# docs内の大容量GeoJSON（PMTilesで配信するため不要）
docs/*/mesh_500m.geojson
docs/*/mesh_250m.geojson

# OS
.DS_Store
Thumbs.db
