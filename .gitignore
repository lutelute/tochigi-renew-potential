# 生成されたHTML・GeoJSON（大容量、再生成可能）
output/*/*.html
output/*/*.geojson
output/*/*.png

# ダウンロードした大容量GISデータ（再取得可能）
data/*/land/

# All-Japan-Gridから抽出したGeoJSON（再生成可能）
data/*/grid/*.geojson

# ポテンシャルGeoJSON（再生成可能）
data/*/potential/*.geojson

# 道路GeoJSON
data/*/grid/*_roads.geojson

# PDFは転載禁止のため除外
data/*/*.pdf

# バッチ実行ログ・チェックポイント
logs/
data/batch_checkpoint.json
data/batch_progress.txt

# ラスタースコア出力 (大容量)
output/*/*.tif

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/

# OS
.DS_Store
Thumbs.db
